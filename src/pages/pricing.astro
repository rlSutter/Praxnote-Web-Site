---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import CTASection from '../components/CTASection.astro';

// Pricing confirmed by founder 2026-05-13. Solo $79 / Group $69 / Enterprise quoted (floor ~$59) /
// Dedicated from $129. Annual prepay ≈17% off. Founder pricing 20% off for life, first 100 practices.
const tiers = [
  {
    name: 'Solo',
    audience: 'For independent clinicians and very small practices.',
    price: '$79',
    unit: 'per clinician · per month',
    annual: 'Annual prepay available on request — saves ≈17%',
    cta: { label: 'Request access', href: '/demo?plan=solo' },
    points: [
      'One clinician seat, AI included',
      'Full documentation, scheduling, billing, client portal',
      '50 AI drafts per month included',
      'Stripe payments, no markup on card fees',
      'BAA included',
    ],
    note: 'Early access — we onboard new practices personally.',
  },
  {
    name: 'Group',
    audience: 'For group practices, 5–24 clinicians, supervisees included.',
    price: '$69',
    unit: 'per active clinician · per month',
    annual: 'Annual prepay available on request — saves ≈17%',
    featured: true,
    cta: { label: 'Request access', href: '/demo?plan=group' },
    points: [
      'Supervision queue, role-based access, audit log',
      'Leave-status seat suspension — pay only for active seats',
      '40 AI drafts per clinician per month, pooled at practice level',
      'Per-therapist CPT rate overrides',
      'Practice admin seat included',
      'BAA included',
    ],
    note: 'Volume discount automatic above 15 clinicians.',
  },
  {
    name: 'Enterprise',
    audience: 'For larger groups (25+) or special compliance needs, on Praxnote Cloud.',
    price: 'Quoted',
    unit: 'starting around $59 / clinician / month',
    annual: 'Annual contracts only',
    cta: { label: 'Talk to us', href: '/contact?topic=enterprise' },
    points: [
      'Everything in Group',
      'Custom AI draft pools and skill libraries (roadmap)',
      'Advanced audit exports',
      'Concierge onboarding',
      'Priority support',
      'Canadian residency on the roadmap',
    ],
    note: 'Most contracts close in 2–4 weeks.',
  },
  {
    name: 'Dedicated',
    audience: 'Praxnote deployed and operated by us, inside your own cloud account.',
    price: 'From $129',
    unit: 'per clinician · per month',
    annual: 'Minimum 10 seats · annual contracts',
    cta: { label: 'Talk to us about Dedicated', href: '/contact?topic=dedicated' },
    points: [
      'Single-tenant deployment in your AWS account (GCP / Azure on the roadmap)',
      'Your data never leaves your cloud boundary',
      'Bring your own Anthropic API key',
      'Same product surface as Cloud, same upgrade cadence',
      'Praxnote operates it — you don\'t carry the ops burden',
      'See the deployment page for the full comparison',
    ],
    note: 'Paid pilot (30 / 60 / 90 days) before annual contract.',
  },
];
---
<BaseLayout
  title="Pricing"
  description="Praxnote pricing. Per active clinician. AI included to a generous monthly limit. No per-client charging. No markup on card processing. Cloud or Dedicated, your choice."
>
  <PageHeader
    eyebrow="Pricing"
    title="Pricing that respects how you actually practice."
    lede="Per active clinician. AI use included. No per-client charging. No markup on card processing. Cloud-hosted or deployed inside your own cloud — same product."
  />

  <section class="founder-strip">
    <div class="container">
      <div class="founder-card">
        <div>
          <span class="badge">Founder pricing</span>
          <h3>20% off, for the life of your contract — first 100 practices.</h3>
          <p>
            We're a small team building Praxnote into the workspace we want behavioral health to have.
            The first 100 practices that sign up get <strong>20% off their tier's price, locked in</strong> —
            not for a year, not until renewal, for as long as you stay.
          </p>
        </div>
        <a href="/demo?plan=founder" class="btn btn-primary">Claim a founder spot</a>
      </div>
    </div>
  </section>

  <section class="tiers">
    <div class="container container-wide">
      <header class="section-head">
        <p class="eyebrow">Four ways to run Praxnote</p>
        <h2>Pick the shape that fits your practice.</h2>
        <p class="lede">
          Three Cloud tiers and one Dedicated tier. The product surface is the same.
          What changes is who operates it, where the data lives, and how the seats are priced.
        </p>
      </header>

      <div class="tier-grid">
        {tiers.map((t) => (
          <article class={t.featured ? 'tier-card tier-featured' : 'tier-card'}>
            {t.featured && <div class="tier-flag">Most practices start here</div>}
            <header class="tier-header">
              <h3>{t.name}</h3>
              <p class="tier-audience">{t.audience}</p>
            </header>
            <div class="tier-price">
              <span class="tier-amount">{t.price}</span>
              <span class="tier-unit">{t.unit}</span>
            </div>
            <p class="tier-annual">{t.annual}</p>
            <a href={t.cta.href} class={t.featured ? 'btn btn-primary tier-cta' : 'btn btn-secondary tier-cta'}>
              {t.cta.label}
            </a>
            <ul class="checks tier-points">
              {t.points.map((p) => <li>{p}</li>)}
            </ul>
            <p class="tier-note">{t.note}</p>
          </article>
        ))}
      </div>

      <p class="tiers-disclaimer">
        Prices in USD. Canadian and other jurisdictions billed in local currency.
        Annual prepay available on request — saves roughly 17% (two months free). All tiers include a BAA.
      </p>
    </div>
  </section>

  <section class="ai-callout">
    <div class="container">
      <div class="grid grid-2">
        <div class="card">
          <h4>AI use, billed honestly</h4>
          <p>
            Every plan includes a monthly AI draft allowance generous enough that most clinicians never
            think about it. If your practice goes over, the overage is billed at <em>our cost from the
            AI provider</em>. We don't mark it up. Practice admins see usage against the limit in-product —
            no support ticket required to check.
          </p>
        </div>
        <div class="card">
          <h4>What never costs extra</h4>
          <p>
            Number of clients. Number of notes. Storage within reason. Document upload. Client portal access.
            Audit log. BAA. Data export when you leave. We charge per active clinician seat. That's it.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="pricing-principles">
    <div class="container">
      <header class="section-head">
        <p class="eyebrow">How we think about pricing</p>
        <h2>Pricing should reflect the value, not the leverage.</h2>
      </header>

      <div class="grid grid-2">
        <div class="card">
          <h4>What we won't do</h4>
          <ul class="checks">
            <li><strong>Per-client pricing.</strong> Charging per chart pushes practices to neglect low-revenue clients. Wrong incentive.</li>
            <li><strong>Cheap intro, steep renewal.</strong> Pricing that triples a year in. Wrong relationship.</li>
            <li><strong>Charging the same whether you use the AI a little or a lot.</strong> A clinician who uses the assistant twice a week shouldn't subsidize one who uses it twice a day.</li>
            <li><strong>Hidden card-processing fees.</strong> Stripe charges what Stripe charges. We don't add anything on top.</li>
            <li><strong>Marking up AI.</strong> Overage is billed at our cost from Anthropic. We can show you the receipts.</li>
          </ul>
        </div>
        <div class="card">
          <h4>What we will do</h4>
          <ul class="checks">
            <li><strong>Charge per active clinician.</strong> If a clinician is on leave, we don't charge for that seat.</li>
            <li><strong>Include a generous AI allowance.</strong> Most practices never hit it.</li>
            <li><strong>Pass card fees through.</strong> Whatever Stripe charges, that's what you pay.</li>
            <li><strong>Keep storage generous.</strong> Documents, transcripts, and recordings within reason. We don't bill for storage during early access; if your practice grows past what "within reason" can cover, we'll have an honest conversation before anything changes.</li>
            <li><strong>Offer founder pricing.</strong> First 100 practices get 20% off for the life of the contract.</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="trial-timeline wash">
    <div class="container container-wide">
      <header class="section-head">
        <p class="eyebrow">How onboarding works</p>
        <h2>From kickoff to first documented session, in under a day.</h2>
        <p class="lede">
          Cloud onboarding is concierge today — we walk you through it on a screen-share. Self-serve sign-up
          is shipping soon. Here's what the first day looks like once your practice is provisioned.
        </p>
      </header>

      <ol class="timeline">
        <li>
          <span class="step-num">01</span>
          <h4>Kickoff call</h4>
          <p>Thirty minutes. We provision your practice and walk through the BAA together.</p>
        </li>
        <li>
          <span class="step-num">02</span>
          <h4>Execute the BAA</h4>
          <p>Click-through. Cryptographically logged. You get a signed copy emailed to you.</p>
        </li>
        <li>
          <span class="step-num">03</span>
          <h4>Provision the practice</h4>
          <p>Add your first clinician seats, set roles, set CPT rate defaults. Five minutes.</p>
        </li>
        <li>
          <span class="step-num">04</span>
          <h4>Document a session</h4>
          <p>Bring a recent session you'd document. Use a global skill or write your own. The AI drafts; you edit; you sign.</p>
        </li>
        <li>
          <span class="step-num">05</span>
          <h4>Invite the team</h4>
          <p>Send invites to clinicians, supervisors, and admins. Each gets a guided onboarding for their role.</p>
        </li>
      </ol>

      <p class="trial-fineprint">
        Dedicated deployments follow a different path — they start with a paid pilot (30 / 60 / 90 days) so we can
        deploy into your cloud account and tear down cleanly if it isn't a fit. <a href="/deployment">See the deployment page.</a>
      </p>
    </div>
  </section>

  <section class="faq">
    <div class="container">
      <header class="section-head">
        <p class="eyebrow">Frequently asked</p>
        <h2>What people ask before signing.</h2>
      </header>

      <div class="faq-list">
        <details>
          <summary>Is sign-up self-serve?</summary>
          <p>
            Not yet — we're in early access and onboard each practice personally so we can hand-hold
            the first day. Self-serve sign-up is coming. In the meantime, <a href="/demo">request access</a>
            and we'll set you up on a screen-share.
          </p>
        </details>
        <details>
          <summary>What's the difference between Group and Enterprise?</summary>
          <p>
            Group is for 5–24 clinicians, with the standard Cloud feature set. Enterprise starts
            at 25 clinicians or earlier if you need custom AI draft pools, larger audit exports,
            concierge onboarding, or in-country Canadian residency. Pricing on Enterprise is quoted
            because the right number depends on which of those you need.
          </p>
        </details>
        <details>
          <summary>What is Praxnote Dedicated, and when is it the right choice?</summary>
          <p>
            Dedicated is Praxnote deployed and operated by us, but inside <em>your</em> AWS account.
            Your data never leaves your boundary. It's the right choice when your
            compliance or risk posture requires that PHI stay in infrastructure you own.
            GCP and Azure are on the roadmap. <a href="/deployment">Compare Cloud and Dedicated.</a>
          </p>
        </details>
        <details>
          <summary>How is AI use counted?</summary>
          <p>
            By the number of drafts the AI helps you produce: session notes, treatment plans,
            letters, and assessment scoring. We track it at the practice level, so individual
            clinicians don't see day-to-day caps. Anything past the monthly limit is billed at
            our cost from the AI provider — no markup.
          </p>
        </details>
        <details>
          <summary>Does "active clinician" mean what I think it means?</summary>
          <p>
            Yes. If a clinician is on leave — parental, medical, sabbatical, between cohorts — you mark
            the seat inactive and we don't bill for it. When they come back, you reactivate. No proration
            games, no minimum durations.
          </p>
        </details>
        <details>
          <summary>What happens if I cancel?</summary>
          <p>
            You export everything: clients, notes, treatment plans, and billing history, in
            standard formats you can take elsewhere. We hold encrypted backups for the six
            years HIPAA requires, then we redact them. No lock-in. No exit penalty.
          </p>
        </details>
        <details>
          <summary>Do you offer nonprofit, training-program, or community-clinic pricing?</summary>
          <p>
            Yes. <a href="/contact?topic=pricing-nonprofit">Get in touch</a> with details about
            your program and we'll structure something that fits.
          </p>
        </details>
        <details>
          <summary>Do you sign a Business Associate Agreement?</summary>
          <p>
            Yes. A BAA is included on every paid plan and during the trial.
            <a href="/security/baa">Request one here.</a>
          </p>
        </details>
      </div>
    </div>
  </section>

  <CTASection
    eyebrow="Two doors, same product"
    heading="Request Cloud access, or talk to us about a Dedicated pilot."
    body="Cloud is in early access — we onboard practices personally. Dedicated starts with a paid pilot inside your AWS account; you keep the keys."
    primaryHref="/demo"
    primaryLabel="Request access"
    secondaryHref="/deployment"
    secondaryLabel="Compare Cloud and Dedicated"
  />
</BaseLayout>

<style>
  /* Founder pricing strip */
  .founder-strip { padding: clamp(1.5rem, 3vw, 2.5rem) 0; }
  .founder-card {
    background: var(--surface-ink);
    color: var(--paper);
    border-radius: var(--radius-lg);
    padding: clamp(1.5rem, 3vw, 2.25rem);
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 2rem;
    align-items: center;
  }
  .founder-card .badge {
    background: var(--terracotta-soft);
    color: var(--terracotta);
    margin-bottom: 0.6rem;
  }
  .founder-card h3 { color: var(--paper); margin-bottom: 0.5rem; max-width: 38ch; }
  .founder-card p { color: rgba(250, 247, 242, 0.72); margin: 0; max-width: 60ch; line-height: 1.6; }
  .founder-card p strong { color: var(--brand-teal-soft); }
  .founder-card .btn-primary { background: var(--paper); color: var(--brand-teal-dark); white-space: nowrap; }
  .founder-card .btn-primary:hover { background: var(--paper-warm); color: var(--brand-teal-dark); }
  @media (max-width: 820px) {
    .founder-card { grid-template-columns: 1fr; }
  }

  /* Tier grid */
  .tiers { padding: clamp(3rem, 5vw, 4.5rem) 0; }
  .section-head { max-width: 720px; margin-bottom: 2.5rem; }

  .tier-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1.25rem;
  }
  @media (max-width: 1100px) { .tier-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
  @media (max-width: 600px) { .tier-grid { grid-template-columns: 1fr; } }

  .tier-card {
    background: var(--surface-card);
    border: 1px solid var(--hairline);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    position: relative;
  }
  .tier-featured {
    border-color: var(--brand-teal);
    box-shadow: 0 12px 32px -16px rgba(29, 84, 72, 0.25);
    background: var(--surface-card);
  }
  .tier-flag {
    position: absolute;
    top: -12px;
    left: 1.75rem;
    background: var(--brand-teal);
    color: var(--paper);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.35rem 0.7rem;
    border-radius: var(--radius-pill);
  }
  .tier-header h3 { margin-bottom: 0.4rem; }
  .tier-audience {
    font-size: 0.88rem;
    color: var(--stone-600);
    line-height: 1.5;
    margin: 0 0 1.25rem;
    min-height: 3.6em;
  }
  .tier-price {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding-bottom: 0.4rem;
  }
  .tier-amount {
    font-family: var(--font-display);
    font-size: 2.4rem;
    font-variation-settings: 'opsz' 96, 'SOFT' 30;
    color: var(--stone-900);
    line-height: 1;
  }
  .tier-unit { font-size: 0.85rem; color: var(--stone-600); }
  .tier-annual {
    margin: 0.4rem 0 1.25rem;
    font-size: 0.82rem;
    color: var(--brand-teal-mid);
    font-style: italic;
  }
  .tier-cta { width: 100%; }
  .tier-points {
    margin-top: 1.25rem;
    gap: 0.55rem;
  }
  .tier-points li { font-size: 0.9rem; }
  .tier-note {
    margin-top: auto;
    padding-top: 1rem;
    font-size: 0.8rem;
    color: var(--stone-500);
    font-style: italic;
  }
  .tiers-disclaimer {
    margin-top: 1.75rem;
    text-align: center;
    color: var(--stone-500);
    font-size: 0.85rem;
  }

  /* AI callout */
  .ai-callout { padding: clamp(2.5rem, 5vw, 4rem) 0; background: var(--paper-warm); }
  .ai-callout .card h4 { margin-bottom: 0.65rem; }
  .ai-callout .card p { color: var(--stone-700); line-height: 1.65; margin: 0; }

  /* Principles */
  .pricing-principles { padding: clamp(2.5rem, 5vw, 4.5rem) 0; }

  /* Trial timeline */
  .trial-timeline { padding: clamp(3rem, 6vw, 5rem) 0; }
  .timeline {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 1.25rem;
    counter-reset: timeline;
  }
  @media (max-width: 980px) { .timeline { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
  @media (max-width: 520px) { .timeline { grid-template-columns: 1fr; } }
  .timeline li {
    background: var(--surface-card);
    border: 1px solid var(--hairline);
    border-radius: var(--radius);
    padding: 1.25rem;
  }
  .step-num {
    display: inline-block;
    font-family: var(--font-display);
    font-size: 0.95rem;
    color: var(--brand-teal);
    letter-spacing: 0.04em;
    margin-bottom: 0.6rem;
    font-variation-settings: 'opsz' 48, 'SOFT' 30;
  }
  .timeline h4 { margin-bottom: 0.35rem; }
  .timeline p { font-size: 0.88rem; color: var(--stone-600); margin: 0; line-height: 1.55; }
  .trial-fineprint {
    margin-top: 2rem;
    color: var(--stone-600);
    font-size: 0.95rem;
    max-width: 720px;
  }

  /* FAQ */
  .faq { padding: clamp(2.5rem, 5vw, 4.5rem) 0; }
  .faq-list { display: flex; flex-direction: column; gap: 0.5rem; max-width: 800px; }
  details {
    background: var(--surface-card);
    border: 1px solid var(--hairline);
    border-radius: var(--radius);
    padding: 1rem 1.25rem;
  }
  details[open] { border-color: var(--brand-teal-soft); }
  details summary {
    cursor: pointer;
    font-family: var(--font-display);
    font-size: 1.1rem;
    color: var(--stone-900);
    font-variation-settings: 'opsz' 48, 'SOFT' 50;
    list-style: none;
    position: relative;
    padding-right: 1.5rem;
  }
  details summary::after {
    content: '+';
    position: absolute;
    right: 0;
    top: 0;
    color: var(--brand-teal);
    font-family: var(--font-sans);
    font-size: 1.4rem;
    font-weight: 300;
  }
  details[open] summary::after { content: '−'; }
  details p { margin-top: 0.85rem; color: var(--stone-600); font-size: 0.95rem; line-height: 1.6; }
</style>
