---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroVisual from '../components/HeroVisual.astro';
import SkillMock from '../components/SkillMock.astro';
import CTASection from '../components/CTASection.astro';

const pillars = [
  {
    title: 'You stay the author',
    body: "Every AI draft is a starting point. The templates that shape the drafts are editable by your practice. Every document is signed by the clinician who wrote it. The AI is your scribe — never your clinician.",
  },
  {
    title: 'Privacy lives in the structure',
    body: "Records are encrypted. The AI is reached directly — no other vendor in between, and the AI provider does not train on your information. Nothing on this site loads from a third-party server. A private, PIN-locked copy can sit on your device for the days the wifi doesn't cooperate.",
  },
  {
    title: 'The format that fits the work',
    body: 'SOAP, DAP, BIRP, plain narrative. PBT/EEMM, CBT, DBT, standard goals-based, simple. Five note formats and five treatment-plan formats — and the freedom to choose which one suits each piece of work.',
  },
];

const personas = [
  {
    title: 'Solo clinicians',
    body: 'Get your evenings back. Drafts in minutes. Your voice, kept.',
    href: '/solutions/solo-clinicians',
  },
  {
    title: 'Group practices',
    body: 'More clinicians, same care. Supervision that respects supervisor time, billing that handles different rates for different clinicians.',
    href: '/solutions/group-practices',
  },
  {
    title: 'Supervisors',
    body: "Thirty notes, twenty minutes, nothing forgotten. One screen for approving, sending back, and setting aside for next week's meeting.",
    href: '/solutions/supervisors',
  },
  {
    title: 'Practice admins',
    body: 'The work of running a practice — calendars, intakes, invoices, consents, audit — in one place built around the role.',
    href: '/solutions/practice-admins',
  },
];
---
<BaseLayout
  title="Notes in minutes. Nuance intact. Control yours."
  description="Praxnote is the clinical workspace for behavioral health. The AI drafts notes, plans, and letters from the context you give it — never replacing your judgment, never reaching client information without your consent."
>
  <section class="hero wash">
    <div class="container hero-grid">
      <div class="hero-text">
        <span class="badge">Built for behavioral health</span>
        <h1>Notes in minutes.<br/><em>Nuance intact.</em><br/>Control yours.</h1>
        <p class="lede">
          Praxnote is the clinical workspace for behavioral health. The AI drafts session notes,
          treatment plans, and client letters from the context <em>you</em> give it — never replacing
          your clinical judgment, never reaching client information without your consent. The AI
          provider we use does not train on what your practice sends.
        </p>
        <p class="hero-deployment">
          <strong>Hosted by us, or running inside your own cloud account.</strong> Same product, your choice — <a href="/deployment">compare Cloud and Dedicated</a>.
        </p>
        <div class="hero-actions">
          <a href="/demo" class="btn btn-primary btn-lg">Request access</a>
          <a href="/pricing" class="btn btn-secondary">See pricing</a>
          <a href="/contact?topic=dedicated" class="btn-ghost">Talk to us about Dedicated →</a>
        </div>
        <p class="hero-fineprint">
          For solo and group practices in the U.S. and Canada · BAA included · right-to-be-forgotten workflows built in · in early access — we onboard each practice personally
        </p>
      </div>
      <div class="hero-visual-wrap">
        <HeroVisual />
      </div>
    </div>
  </section>

  <aside class="trust-line">
    <div class="container">
      <p>Encrypted by default. BAA included. Right-to-be-forgotten built in. <a href="/security">The AI is reached directly — no other vendor in between, no analytics, no training on your information.</a></p>
    </div>
  </aside>

  <section class="pillars">
    <div class="container">
      <header class="section-head">
        <p class="eyebrow">Three commitments</p>
        <h2>Built into how the product works, <em>not into a policy page.</em></h2>
      </header>

      <ol class="pillar-row">
        {pillars.map((p, i) => (
          <li class="pillar-card">
            <span class="pillar-num">{String(i + 1).padStart(2, '0')}</span>
            <h3>{p.title}</h3>
            <p>{p.body}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section class="showcase">
    <div class="container">
      <div class="showcase-grid">
        <div class="showcase-text">
          <p class="eyebrow">Show the instructions, not the magic</p>
          <h2>Every AI draft starts here. <em>An editable template, written in plain language.</em></h2>
          <p class="lede">
            Most AI scribes treat the prompt as a trade secret. Praxnote treats it as something
            the practice can read and adjust. When you change a template for your practice, your
            version is what every clinician on the team sees from that moment on — until you
            change it again.
          </p>
          <p>
            Fourteen templates come ready on day one: session notes, treatment plans in five
            formats, referral letters, discharge summaries, case conceptualizations, and others.
            Each one is yours to edit. Each draft a clinician makes is kept alongside the exact
            version of the template that shaped it.
          </p>
          <a href="/features/ai-skills" class="showcase-link">Read about the templates →</a>
        </div>
        <div class="showcase-visual">
          <SkillMock />
          <p class="caption">An actual Praxnote template. Open in the product, change it, publish.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="supervision-band">
    <div class="container">
      <div class="supervision-grid">
        <div class="supervision-text">
          <p class="eyebrow">Where supervision actually happens</p>
          <h2>One screen for <em>thirty-note Fridays.</em></h2>
          <p>
            Most clinical software treats supervision as a checkbox. Praxnote treats it as the
            work it actually is — one screen where every supervisee's recent notes are visible,
            three clear decisions for each one, and a record of every decision that survives
            the year. Twenty minutes for what used to take an unreadable Friday inbox.
          </p>
          <p class="supervision-cta">
            <a href="/features/supervision" class="showcase-link">See how the screen works →</a>
          </p>
        </div>
        <div class="supervision-keys">
          <div class="key-row">
            <span class="action-name">Approve</span>
            <span>For notes that meet your standard</span>
          </div>
          <div class="key-row">
            <span class="action-name">Send back</span>
            <span>For notes that need another pass</span>
          </div>
          <div class="key-row">
            <span class="action-name">Set aside</span>
            <span>For something worth discussing at supervision</span>
          </div>
          <p class="key-fineprint">
            Click anything, or fly through with single-key shortcuts.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="personas section-ink">
    <div class="container">
      <header class="section-head">
        <p class="eyebrow">Who Praxnote is for</p>
        <h2>Behavioral health, end to end.</h2>
        <p class="lede">
          From a solo clinician with twenty-five clients a week to a group practice with five
          supervisors and a full operations team — each role has a seat built around the
          work that role actually does.
        </p>
      </header>

      <div class="grid grid-3 persona-grid">
        {personas.map((p) => (
          <a class="persona-card" href={p.href}>
            <h3>{p.title}</h3>
            <p>{p.body}</p>
            <span class="persona-arrow" aria-hidden="true">→</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CTASection
    eyebrow="Two doors. Same product."
    heading="Request Cloud access, or talk to us about a Dedicated pilot."
    body="Cloud trial is self-serve — you'll be documenting your first session in under a day. Dedicated starts with a paid pilot, deployed into your own cloud account, with a documented teardown path if it isn't a fit."
    primaryHref="/demo"
    primaryLabel="Request access"
    secondaryHref="/deployment"
    secondaryLabel="Compare Cloud and Dedicated"
  />
</BaseLayout>

<style>
  .hero { padding: clamp(3rem, 6vw, 5rem) 0 clamp(3rem, 5vw, 5rem); }

  .hero-grid {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }

  .hero-text { max-width: 580px; }
  .hero-text h1 { margin: 1.25rem 0 1.5rem; }
  .hero-text .lede { margin-bottom: 0; }

  .hero-actions {
    margin-top: 2rem;
    display: flex;
    gap: 1rem;
    align-items: center;
    flex-wrap: wrap;
  }

  .btn-lg { padding: 1rem 1.9rem; font-size: 1rem; }

  .hero-fineprint {
    margin-top: 1.25rem;
    color: var(--stone-500);
    font-size: 0.88rem;
  }

  .hero-deployment {
    margin-top: 1.25rem;
    padding: 0.8rem 1rem;
    background: var(--paper-warm);
    border-left: 3px solid var(--brand-teal);
    border-radius: 0 var(--radius) var(--radius) 0;
    font-size: 0.95rem;
    color: var(--stone-700);
  }
  .hero-deployment strong { color: var(--stone-900); }
  .hero-deployment a {
    color: var(--brand-teal-dark);
    text-decoration: none;
    border-bottom: 1px solid var(--brand-teal-soft);
  }
  .hero-deployment a:hover { border-bottom-color: var(--brand-teal); }

  @media (max-width: 920px) {
    .hero-grid { grid-template-columns: 1fr; }
    .hero-visual-wrap { order: -1; max-width: 460px; margin: 0 auto; }
  }

  /* One-sentence trust band */
  .trust-line {
    border-top: 1px solid var(--hairline);
    border-bottom: 1px solid var(--hairline);
    background: var(--paper-warm);
    padding: 1.1rem 0;
  }
  .trust-line p {
    font-size: 0.95rem;
    color: var(--stone-700);
    margin: 0;
    line-height: 1.55;
  }
  .trust-line a {
    color: var(--brand-teal-dark);
    text-decoration: none;
    border-bottom: 1px dotted var(--hairline-strong);
  }
  .trust-line a:hover { border-bottom-color: var(--brand-teal); }

  /* Three commitments */
  .pillars { padding: clamp(3.5rem, 6vw, 5.5rem) 0; }
  .section-head { max-width: 720px; margin-bottom: 2.5rem; }
  .section-head .lede { margin-top: 1rem; }

  .pillar-row {
    list-style: none;
    counter-reset: pillar;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    border-top: 1px solid var(--hairline);
    border-bottom: 1px solid var(--hairline);
  }
  .pillar-card {
    padding: 2rem 1.75rem 1.75rem 0;
    margin-right: 1.75rem;
    border-right: 1px solid var(--hairline);
    background: transparent;
  }
  .pillar-card:last-child { border-right: 0; margin-right: 0; }
  .pillar-num {
    display: block;
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-variation-settings: 'opsz' 48, 'SOFT' 30;
    color: var(--brand-teal);
    letter-spacing: 0.02em;
    margin-bottom: 1rem;
  }
  .pillar-card h3 { margin-bottom: 0.6rem; max-width: 18ch; }
  .pillar-card p { color: var(--stone-600); font-size: 0.98rem; line-height: 1.6; max-width: 38ch; }
  @media (max-width: 920px) {
    .pillar-row { grid-template-columns: 1fr; }
    .pillar-card { padding: 1.5rem 0; margin-right: 0; border-right: 0; border-bottom: 1px solid var(--hairline); }
    .pillar-card:last-child { border-bottom: 0; }
  }

  /* Skill mock centerpiece */
  .showcase {
    padding: clamp(4rem, 7vw, 6.5rem) 0;
    background: var(--paper-warm);
    border-bottom: 1px solid var(--hairline);
  }
  .showcase-grid {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: clamp(2rem, 5vw, 4.5rem);
    align-items: center;
  }
  .showcase-text { max-width: 520px; }
  .showcase-text h2 { margin: 0.4rem 0 1.25rem; }
  .showcase-text .lede { margin-bottom: 1rem; color: var(--stone-700); }
  .showcase-text p { color: var(--stone-700); line-height: 1.7; }
  .showcase-link {
    display: inline-block;
    margin-top: 1rem;
    color: var(--brand-teal-dark);
    text-decoration: none;
    font-weight: 600;
    border-bottom: 1px solid var(--brand-teal-soft);
    padding-bottom: 1px;
  }
  .showcase-link:hover { border-bottom-color: var(--brand-teal); }
  .showcase-visual { display: flex; flex-direction: column; gap: 0.85rem; }
  .showcase-visual .caption {
    font-size: 0.85rem;
    color: var(--stone-500);
    margin: 0;
    text-align: center;
    font-style: italic;
  }

  @media (max-width: 920px) {
    .showcase-grid { grid-template-columns: 1fr; }
    .showcase-visual { order: 2; }
  }

  /* Supervision band */
  .supervision-band {
    padding: clamp(3.5rem, 6vw, 5.5rem) 0;
    border-bottom: 1px solid var(--hairline);
  }
  .supervision-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }
  .supervision-text { max-width: 580px; }
  .supervision-text h2 { margin: 0.4rem 0 1.25rem; }
  .supervision-text p { color: var(--stone-700); line-height: 1.7; }
  .supervision-cta { margin-top: 1.25rem; }
  .supervision-keys {
    background: var(--surface-card);
    border: 1px solid var(--hairline);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .key-row {
    display: grid;
    grid-template-columns: 110px 1fr;
    align-items: baseline;
    gap: 1rem;
    padding: 0.95rem 0;
    border-bottom: 1px solid var(--hairline);
  }
  .key-row:first-of-type { padding-top: 0; }
  .key-row:nth-of-type(3) { border-bottom: none; padding-bottom: 0.5rem; }
  .action-name {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-variation-settings: 'opsz' 48, 'SOFT' 50;
    color: var(--brand-teal-dark);
  }
  .key-row span:not(.action-name) {
    color: var(--stone-700);
    font-size: 0.92rem;
    line-height: 1.5;
  }
  .key-fineprint {
    margin: 0.85rem 0 0;
    padding-top: 0.85rem;
    border-top: 1px solid var(--hairline);
    color: var(--stone-500);
    font-size: 0.85rem;
    font-style: italic;
  }
  @media (max-width: 920px) {
    .supervision-grid { grid-template-columns: 1fr; }
  }

  /* Personas dark band */
  .personas .section-head { margin-bottom: 2.5rem; }
  .persona-grid { margin-top: 1rem; }

  .personas .persona-card {
    background: rgba(250, 247, 242, 0.04);
    border: 1px solid rgba(250, 247, 242, 0.08);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
    text-decoration: none;
    color: var(--paper);
    transition: background 200ms ease, border-color 200ms ease;
    position: relative;
  }
  .personas .persona-card:hover {
    background: rgba(250, 247, 242, 0.07);
    border-color: rgba(213, 196, 165, 0.3);
  }
  .personas .persona-card h3 { color: var(--paper); margin-bottom: 0.5rem; }
  .personas .persona-card p { color: rgba(250, 247, 242, 0.65); font-size: 0.95rem; line-height: 1.55; }
  .persona-arrow {
    position: absolute;
    bottom: 1.5rem;
    right: 1.5rem;
    color: var(--brand-teal-soft);
    font-size: 1.1rem;
  }
</style>
