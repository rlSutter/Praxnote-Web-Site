---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import CTASection from '../../components/CTASection.astro';

const guides = [
  { title: 'SOAP, DAP, BIRP — when each note format fits', summary: 'A clinician\'s guide to the traditional note formats and the kind of session each one suits best.', tag: 'Documentation' },
  { title: 'Process-Based Therapy for clinicians who haven\'t tried it yet', summary: 'A practical introduction to PBT and the EEMM matrix, with a worked example of what a treatment plan looks like.', tag: 'Modality' },
  { title: 'Right-to-be-forgotten for US-based therapists with European clients', summary: 'What the right-to-erasure means in practice, how it sits alongside the U.S. records-retention rules, and what your workflow needs to be able to do.', tag: 'Compliance' },
  { title: 'Building a supervision workflow that holds up', summary: 'How to design a supervision practice that handles thirty notes a week without burning out the supervisor or the supervisees.', tag: 'Operations' },
  { title: 'AI in clinical practice — what "in your workflow" should actually mean', summary: 'A practical way to think about AI in a clinical context, past the marketing and past the fear.', tag: 'Ethics' },
  { title: 'Documentation burden and clinician burnout', summary: 'What the research says about documentation load in behavioral health, and what a faster, calmer documentation experience actually changes.', tag: 'Clinician wellbeing' },
];
---
<BaseLayout
  title="Guides"
  description="Long-form guides on documentation craft, treatment-plan modalities, compliance, and behavioral-health operations."
>
  <PageHeader
    eyebrow="Guides"
    title="Long-form. <em>Considered.</em> Free."
    lede="Pieces we wrote because the same questions kept coming up — from clinicians, supervisors, and practice owners thinking through whether a documentation platform is right for them. Drafts of these are in progress; let us know which one you'd like first and we'll send it when it's ready."
  />

  <section class="guide-list">
    <div class="container">
      <ul class="list">
        {guides.map((g) => (
          <li class="guide-item">
            <span class="badge badge-stone">{g.tag}</span>
            <h3>{g.title}</h3>
            <p>{g.summary}</p>
            <span class="muted">Coming soon</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <CTASection
    eyebrow="Want a heads-up when each lands?"
    heading="We'll email you when a guide is published. Nothing else."
    body="Tell us which topic you'd like first and we'll send you that piece the moment it's ready. We don't send unrelated marketing email — we don't have a marketing list."
    primaryHref="/contact?topic=guides"
    primaryLabel="Email me when published"
    secondaryHref="/demo"
    secondaryLabel="Or request access"
    variant="paper"
  />
</BaseLayout>

<style>
  .guide-list { padding: clamp(2rem, 4vw, 3.5rem) 0; }
  .list { list-style: none; padding: 0; margin: 0; display: grid; gap: 1rem; }
  .guide-item {
    background: var(--surface-card);
    border: 1px solid var(--hairline);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .guide-item h3 { font-size: 1.3rem; }
  .guide-item p { color: var(--stone-600); font-size: 0.98rem; line-height: 1.6; max-width: 720px; }
  .badge { align-self: flex-start; }
</style>
