---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import CTASection from '../../components/CTASection.astro';
import SkillMock from '../../components/SkillMock.astro';

const skills = [
  { name: 'Session note', detail: 'SOAP — the default' },
  { name: 'Session note', detail: 'detailed narrative' },
  { name: 'Session plan', detail: 'planning the next session' },
  { name: 'Diagnosis', detail: 'differential and rationale' },
  { name: 'Case conceptualization', detail: 'detailed' },
  { name: 'Treatment plan', detail: 'PBT / EEMM' },
  { name: 'Treatment plan', detail: 'standard goals-based' },
  { name: 'Treatment plan', detail: 'CBT' },
  { name: 'Treatment plan', detail: 'DBT' },
  { name: 'Treatment plan', detail: 'simple 3-month' },
  { name: 'Referral letter', detail: 'to a colleague or specialist' },
  { name: 'Leave-of-absence letter', detail: 'for clients on a clinical break' },
  { name: 'Discharge summary', detail: 'end-of-care documentation' },
  { name: 'Assessment results letter', detail: 'in clinician or client voice' },
];
---
<BaseLayout
  title="AI skills"
  description="A skill is the editable template behind every AI draft in Praxnote. You can read it. You can change it. Your changes apply only to your practice."
>
  <PageHeader
    eyebrow="AI skills"
    title="The instructions are right there. <em>Read them. Change them. Make them yours.</em>"
    lede="Most AI scribes treat the prompt as a trade secret. Praxnote treats it as something the practice should be able to see, edit, and own. A skill is the editable template that shapes one kind of clinical document — and every change to it is recorded."
  >
    <a href="/demo" class="btn btn-primary btn-lg">Request access</a>
    <a href="#what-skills-are" class="btn btn-secondary">What is a skill?</a>
  </PageHeader>

  <section class="explain" id="what-skills-are">
    <div class="container">
      <div class="explain-grid">
        <div class="explain-text">
          <p class="eyebrow">What a skill is</p>
          <h2>An editable template that shapes one clinical document.</h2>
          <p>
            A skill is written in plain language, in clinical voice. It tells the AI how the
            document should be shaped — the voice to write in, the structure of the result,
            the things that have to be included, the things that should never appear. Nothing
            is hidden behind it. The instructions you read are the instructions the AI follows.
          </p>
          <p>
            Every AI draft in Praxnote — a session note, a treatment plan, a referral letter,
            a case conceptualization — comes from one skill. Your practice can copy any skill
            and change its wording to match how you actually work. If you've made your own
            version, that's what your clinicians use. If you haven't, the Praxnote default is
            what they see.
          </p>
          <p>
            <strong>Every change to a skill is recorded.</strong> When you edit a skill, the
            change is saved with the time and the name of who made it. When a clinician
            generates a draft, the exact version of the skill in effect at that moment is
            saved alongside the document, so a future supervisor or audit can see what shaped
            the note.
          </p>
        </div>
        <div class="explain-visual">
          <SkillMock />
        </div>
      </div>
    </div>
  </section>

  <section class="shipped section-ink">
    <div class="container">
      <header class="section-head">
        <p class="eyebrow">Skills that ship</p>
        <h2>Fourteen ready on day one. <em>Yours to change.</em></h2>
        <p class="lede">
          Every Praxnote practice has these available from the start. Each one is yours to read,
          adjust, and tune to your clinical voice.
        </p>
      </header>

      <ol class="skills-list">
        {skills.map((s, i) => (
          <li>
            <span class="num">{String(i + 1).padStart(2, '0')}</span>
            <span class="sk-name">{s.name}</span>
            <span class="sk-detail">{s.detail}</span>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section class="resolution">
    <div class="container">
      <header class="section-head">
        <p class="eyebrow">Whose version your clinicians see</p>
        <h2>Your practice's version if you've made one. <em>Otherwise the default.</em></h2>
      </header>

      <div class="grid grid-2 res-grid">
        <div class="card">
          <h3>If your practice hasn't customized</h3>
          <p>Your clinicians use the Praxnote default — written and reviewed by us, available for you to read at any time. Most practices start here.</p>
        </div>
        <div class="card">
          <h3>If your practice has customized</h3>
          <p>Your version is what your clinicians see. Other practices keep their own. No overlap. No surprise about which version was in effect when.</p>
        </div>
      </div>
    </div>
  </section>

  <CTASection
    eyebrow="See a real skill"
    heading="Walk through a skill, on your modality."
    body="On a walk-through we'll open a real skill, change a piece of it together, and generate a draft from a sample session. You'll leave with a clear sense of how the editing actually works."
    primaryHref="/demo"
    primaryLabel="Book a walk-through"
    secondaryHref="/features/session-notes"
    secondaryLabel="How session notes work"
  />
</BaseLayout>

<style>
  .explain { padding: clamp(3rem, 5vw, 4.5rem) 0; }
  .explain-grid { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(2rem, 5vw, 4rem); align-items: start; }
  .explain-text p { color: var(--stone-700); line-height: 1.7; margin-bottom: 1rem; }

  @media (max-width: 920px) {
    .explain-grid { grid-template-columns: 1fr; }
  }

  .skills-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.5rem 1.5rem;
    counter-reset: none;
  }
  .skills-list li {
    display: grid;
    grid-template-columns: 32px 1.4fr 1fr;
    align-items: baseline;
    gap: 0.85rem;
    padding: 0.5rem 0;
    border-bottom: 1px solid rgba(250, 247, 242, 0.08);
    color: rgba(250, 247, 242, 0.85);
    font-size: 0.96rem;
  }
  .skills-list .num {
    color: var(--brand-teal-soft);
    font-family: var(--font-display);
    font-size: 0.95rem;
  }
  .skills-list .sk-name { color: rgba(250, 247, 242, 0.92); font-weight: 500; }
  .skills-list .sk-detail { color: rgba(250, 247, 242, 0.55); font-size: 0.88rem; }

  @media (max-width: 700px) { .skills-list { grid-template-columns: 1fr; } }

  .section-head { max-width: 760px; margin-bottom: 2.5rem; }
  .section-head .lede { margin-top: 1rem; }
  .resolution { padding: clamp(3rem, 5vw, 4.5rem) 0; }
  .card h3 { margin-bottom: 0.5rem; }
  .card p { color: var(--stone-700); font-size: 0.95rem; line-height: 1.65; }
</style>
