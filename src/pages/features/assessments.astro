---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import CTASection from '../../components/CTASection.astro';

const instruments = [
  { name: 'ASRS-5', full: 'Adult ADHD Self-Report Screening Scale for DSM-5', use: 'Adult ADHD self-report' },
  { name: 'ACE', full: 'Adverse Childhood Experiences', use: 'Childhood adversity' },
  { name: 'BDI-II', full: "Beck's Depression Inventory", use: 'Depression severity (Beck, 21-item)' },
  { name: 'CAT-Q', full: 'Camouflaging Autistic Traits Questionnaire', use: 'Autism camouflaging' },
  { name: 'C-SSRS', full: 'Columbia-Suicide Severity Rating Scale', use: 'Suicide-severity risk' },
  { name: 'DES-II', full: 'Dissociative Experiences Scale II', use: 'Dissociative experiences' },
  { name: 'DVR Functional', full: 'DVR Vocational Services Authorization and Functional Assessment', use: 'Vocational services and functioning' },
  { name: 'EPDS', full: 'Edinburgh Postnatal Depression Scale', use: 'Postnatal depression' },
  { name: 'GAIN-SS', full: 'GAIN Short Screener', use: 'Substance-use and mental-health screen' },
  { name: 'GAD-7', full: 'Generalized Anxiety Disorder 7-item Scale', use: 'Generalized anxiety' },
  { name: 'PHQ-9', full: 'Patient Health Questionnaire-9', use: 'Depression severity (9-item)' },
  { name: 'PC-PTSD-5', full: 'Primary Care PTSD Screen for DSM-5', use: 'Primary-care PTSD screen' },
  { name: 'PROMIS Dep.', full: 'PROMIS Emotional Distress, Depression, Age 11-17', use: 'Adolescent depression (ages 11-17)' },
  { name: 'PCL-5', full: 'PTSD Checklist for DSM-5', use: 'PTSD symptom checklist' },
  { name: 'RAADS-R', full: 'Ritvo Autism Asperger Diagnostic Scale-Revised', use: 'Autism (adult, self-report)' },
  { name: 'SAFETY-PLAN', full: 'Safety Plan', use: 'Suicide-risk safety planning' },
  { name: 'SWLS', full: 'Satisfaction With Life Scale', use: 'Subjective wellbeing' },
  { name: 'Sensory', full: 'Sensory Assessment', use: 'Sensory processing' },
  { name: 'WHODAS 2.0', full: 'WHODAS 2.0 (12-item)', use: 'Functional disability' },
  { name: 'Y-BOCS', full: 'Yale-Brown Obsessive Compulsive Scale', use: 'OCD severity' },
];
---
<BaseLayout
  title="Assessments"
  description="Twenty validated assessment instruments built in. Upload a completed form, get a scored result on the chart. Severity bands and interpretations you can adjust for your population."
>
  <PageHeader
    eyebrow="Assessments"
    title="Validated instruments. Score from a file. <em>Land on the chart.</em>"
    lede="Praxnote ships with twenty validated assessments. Upload a completed form in almost any format, and the scored result lands on the client's record. The interpretations and severity bands are clinician-editable for the populations you actually see."
  >
    <a href="/demo" class="btn btn-primary btn-lg">Request access</a>
  </PageHeader>

  <section class="instruments">
    <div class="container">
      <header class="section-head">
        <p class="eyebrow">Instruments included</p>
        <h2>Twenty validated assessments, ready to use.</h2>
        <p class="lede">
          Adding more is something we can do without writing new code — they're set up in the
          same editable structure as everything else in Praxnote.
        </p>
      </header>

      <ul class="instr-grid" role="list">
        {instruments.map((i) => (
          <li class="instr-card" title={i.full}>
            <span class="instr-name">{i.name}</span>
            <span class="instr-use">{i.use}</span>
            <span class="instr-full">{i.full}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="upload section-ink">
    <div class="container">
      <header class="section-head">
        <p class="eyebrow">From a file to a scored result</p>
        <h2>Drop in the form. <em>Get a result back.</em></h2>
        <p class="lede">
          Praxnote accepts the form however the client gave it to you — PDF, image, Word, Excel,
          CSV, RTF. The scoring happens in steps, with a careful safety check for the simple
          paper-and-pen forms that sometimes don't scan cleanly the first time.
        </p>
      </header>

      <ol class="pipeline">
        <li>
          <span class="step">1</span>
          <h4>Read the form</h4>
          <p>Praxnote pulls the client's answers off whatever file you gave it, in whatever format the form happened to be in.</p>
        </li>
        <li>
          <span class="step">2</span>
          <h4>Apply your scoring</h4>
          <p>Each instrument has its own scoring rules. If your practice has adjusted them, your version applies. Otherwise the Praxnote default does.</p>
        </li>
        <li>
          <span class="step">3</span>
          <h4>Produce the result</h4>
          <p>The scoring is applied to the answers and the result is produced in the shape your clinicians expect — total score, sub-scales, severity band.</p>
        </li>
        <li>
          <span class="step">4</span>
          <h4>Cross-check</h4>
          <p>For straightforward question-and-answer forms, Praxnote re-scores the form a second way and compares the two — a quiet safety check that you don't have to think about.</p>
        </li>
        <li>
          <span class="step">5</span>
          <h4>Onto the chart</h4>
          <p>The scored assessment lands on the client's record, linked back to the file you uploaded. The clinician reviews it from the chart.</p>
        </li>
      </ol>
    </div>
  </section>

  <section class="micro-skills">
    <div class="container">
      <header class="section-head">
        <p class="eyebrow">Severity bands you can shape</p>
        <h2>The interpretation is editable, too.</h2>
        <p class="lede">
          The scoring rules and the severity-band interpretations are written in plain language and
          editable per practice. Some clinical populations need different severity cutoffs than the
          ones that ship as defaults — your practice can adjust them and your version will apply
          from then on.
        </p>
      </header>

      <div class="grid grid-2">
        <div class="card">
          <h4>Why this matters</h4>
          <p>Severity bands aren't universal. A PHQ-9 of 12 can mean different things in different populations. Letting your practice shape the interpretation lets the clinical voice come through, without changing how the underlying score is calculated.</p>
        </div>
        <div class="card">
          <h4>What you can change</h4>
          <p>The cutoffs, the wording of each severity band, the interpretation paragraphs the clinician sees, and the paragraphs the client sees in their version. Each is a plain-language edit that applies to your practice only.</p>
        </div>
      </div>
    </div>
  </section>

  <CTASection
    eyebrow="See it on a real form"
    heading="Bring a PHQ-9 or a GAD-7. We'll score it on the walk-through."
    body="On most walk-throughs we run a real (or sanitized) form through scoring live. You'll see the result, the severity band, and how it lands on the chart."
    primaryHref="/demo"
    primaryLabel="Book a walk-through"
    secondaryHref="/features/session-notes"
    secondaryLabel="See session notes"
  />
</BaseLayout>

<style>
  .instruments { padding: clamp(3rem, 5vw, 4.5rem) 0; }
  .micro-skills { padding: clamp(3rem, 5vw, 4.5rem) 0; }
  .section-head { max-width: 760px; margin-bottom: 2.5rem; }
  .section-head .lede { margin-top: 1rem; }
  .instr-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 0.85rem;
  }
  .instr-card {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    background: var(--surface-card);
    border: 1px solid var(--hairline);
    border-radius: var(--radius);
    padding: 1.05rem 1.2rem 1.1rem;
  }
  .instr-name {
    font-family: var(--font-display);
    font-size: 1.3rem;
    line-height: 1.05;
    color: var(--brand-teal-dark);
    font-variation-settings: 'opsz' 60, 'SOFT' 30;
  }
  .instr-use {
    font-size: 0.88rem;
    color: var(--stone-700);
    margin-top: 0.15rem;
  }
  .instr-full {
    font-size: 0.78rem;
    color: var(--stone-500);
    margin-top: 0.4rem;
    line-height: 1.4;
  }

  .pipeline {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 0;
    border-top: 1px solid rgba(250, 247, 242, 0.08);
    border-bottom: 1px solid rgba(250, 247, 242, 0.08);
  }
  .pipeline li {
    padding: 1.5rem 1.25rem;
    border-right: 1px solid rgba(250, 247, 242, 0.08);
  }
  .pipeline li:last-child { border-right: 0; }
  .pipeline .step {
    display: inline-block;
    font-family: var(--font-display);
    font-size: 1.6rem;
    color: var(--brand-teal-soft);
    margin-bottom: 0.5rem;
  }
  .pipeline h4 { color: var(--paper); font-size: 1rem; font-family: var(--font-sans); font-weight: 600; margin-bottom: 0.4rem; }
  .pipeline p { color: rgba(250, 247, 242, 0.6); font-size: 0.88rem; line-height: 1.55; }

  @media (max-width: 1100px) { .pipeline { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 600px) { .pipeline { grid-template-columns: 1fr; } .pipeline li { border-right: 0; border-bottom: 1px solid rgba(250, 247, 242, 0.08); } }

  .card h4 { font-family: var(--font-sans); font-size: 1.05rem; font-weight: 600; margin-bottom: 0.5rem; }
  .card p { color: var(--stone-700); font-size: 0.95rem; line-height: 1.65; }
</style>
