---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import CTASection from '../../components/CTASection.astro';

const instruments = [
  { name: 'ASRS-5', full: 'Adult ADHD Self-Report Screening Scale for DSM-5', use: 'Adult ADHD self-report' },
  { name: 'ACE', full: 'Adverse Childhood Experiences', use: 'Childhood adversity' },
  { name: 'BDI-II', full: "Beck's Depression Inventory", use: 'Depression severity (Beck, 21-item)' },
  { name: 'CAT-Q', full: 'Camouflaging Autistic Traits Questionnaire', use: 'Autism camouflaging' },
  { name: 'C-SSRS', full: 'Columbia-Suicide Severity Rating Scale', use: 'Suicide-severity risk' },
  { name: 'DES-II', full: 'Dissociative Experiences Scale II', use: 'Dissociative experiences' },
  { name: 'DVR Functional', full: 'DVR Vocational Services Authorization and Functional Assessment', use: 'Vocational services and functioning' },
  { name: 'EPDS', full: 'Edinburgh Postnatal Depression Scale', use: 'Postnatal depression' },
  { name: 'GAIN-SS', full: 'GAIN Short Screener', use: 'Substance-use and mental-health screen' },
  { name: 'GAD-7', full: 'Generalized Anxiety Disorder 7-item Scale', use: 'Generalized anxiety' },
  { name: 'PHQ-9', full: 'Patient Health Questionnaire-9', use: 'Depression severity (9-item)' },
  { name: 'PC-PTSD-5', full: 'Primary Care PTSD Screen for DSM-5', use: 'Primary-care PTSD screen' },
  { name: 'PROMIS Dep.', full: 'PROMIS Emotional Distress, Depression, Age 11-17', use: 'Adolescent depression (ages 11-17)' },
  { name: 'PCL-5', full: 'PTSD Checklist for DSM-5', use: 'PTSD symptom checklist' },
  { name: 'RAADS-R', full: 'Ritvo Autism Asperger Diagnostic Scale-Revised', use: 'Autism (adult, self-report)' },
  { name: 'SAFETY-PLAN', full: 'Safety Plan', use: 'Suicide-risk safety planning' },
  { name: 'SWLS', full: 'Satisfaction With Life Scale', use: 'Subjective wellbeing' },
  { name: 'Sensory', full: 'Sensory Assessment', use: 'Sensory processing' },
  { name: 'WHODAS 2.0', full: 'WHODAS 2.0 (12-item)', use: 'Functional disability' },
  { name: 'Y-BOCS', full: 'Yale-Brown Obsessive Compulsive Scale', use: 'OCD severity' },
];
---
<BaseLayout
  title="Assessments"
  description="Twenty built-in validated instruments (PHQ-9, GAD-7, PCL-5, ACE, BDI-II, C-SSRS, RAADS-R, and more) with upload-and-score extraction and a deterministic safety net. Custom scoring rules per instrument."
>
  <PageHeader
    eyebrow="Assessments"
    title="Validated instruments. Upload-and-score. <em>Routed back to the chart.</em>"
    lede="Praxnote ships with twenty validated instruments and the infrastructure to add more without code changes. Scores route automatically into the client record. Severity bands and interpretations come from per-instrument scoring rules you can override per practice."
  >
    <a href="/demo" class="btn btn-primary btn-lg">Book a demo</a>
  </PageHeader>

  <section class="instruments">
    <div class="container">
      <header class="section-head">
        <p class="eyebrow">Instruments shipped</p>
        <h2>Twenty validated instruments out of the box.</h2>
        <p class="lede">
          Adding more is an assessment-builder change, not an engineering one.
        </p>
      </header>

      <ul class="instr-grid" role="list">
        {instruments.map((i) => (
          <li class="instr-card" title={i.full}>
            <span class="instr-name">{i.name}</span>
            <span class="instr-use">{i.use}</span>
            <span class="instr-full">{i.full}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="upload section-ink">
    <div class="container">
      <header class="section-head">
        <p class="eyebrow">Upload-and-score pipeline</p>
        <h2>Drop in a file. Get a scored assessment back.</h2>
        <p class="lede">
          Praxnote's scoring tool accepts PDFs, images, Word, Excel, CSV, and RTF files. It
          works in stages, with a clinician-grade safety net for plain-text PDFs that don't
          quite scan cleanly the first time.
        </p>
      </header>

      <ol class="pipeline">
        <li><span class="step">1</span><h4>Read the file</h4><p>Praxnote pulls the answers off whatever you uploaded, no matter the format.</p></li>
        <li><span class="step">2</span><h4>Find the scoring rules</h4><p>Each instrument has its own scoring rules. Your practice's customized rules apply first; the Praxnote default fills in if you haven't customized.</p></li>
        <li><span class="step">3</span><h4>Score it</h4><p>The AI applies the scoring rules to the answers and produces a result in the form your clinicians expect.</p></li>
        <li><span class="step">4</span><h4>Cross-check the result</h4><p>For straightforward "question, then answer" PDFs, a second clinician-grade safety net re-scores the form to make sure the AI got it right.</p></li>
        <li><span class="step">5</span><h4>Land it on the chart</h4><p>The scored assessment lands in the client's record, linked back to the file you uploaded. The clinician reviews it from the chart.</p></li>
      </ol>
    </div>
  </section>

  <section class="micro-skills">
    <div class="container">
      <header class="section-head">
        <p class="eyebrow">Scoring micro-skills</p>
        <h2>The scoring rules are skills, too.</h2>
        <p class="lede">
          Every instrument has a dedicated scoring skill: plain text, editable, audit-logged.
          Practices can override the global scoring skill for their patient population (for
          example, adjusting severity bands for a specific demographic).
        </p>
      </header>

      <div class="grid grid-2">
        <div class="card">
          <h4>Why this matters</h4>
          <p>Severity bands aren't universal. A PHQ-9 of 12 means different things in different contexts. Letting practices customize the scoring skill (without changing how scores propagate) lets clinical voice flow through the data.</p>
        </div>
        <div class="card">
          <h4>What you can change</h4>
          <p>Cutoffs, severity language, interpretation paragraphs, dual-mode (provider vs client) phrasing. Each is a plain-text edit, deployed to your practice only.</p>
        </div>
      </div>
    </div>
  </section>

  <CTASection
    eyebrow="See an assessment scored"
    heading="Bring a PDF. We'll score it on the demo."
    body="Most demos run an upload-and-score on a real (or sanitized) PHQ-9 PDF. You'll see the score, the severity band, and how it lands on the chart."
  />
</BaseLayout>

<style>
  .instruments { padding: clamp(3rem, 5vw, 4.5rem) 0; }
  .section-head { max-width: 720px; margin-bottom: 2.5rem; }
  .section-head .lede { margin-top: 1rem; }
  code { font-family: ui-monospace, 'SF Mono', Menlo, Consolas, monospace; background: var(--paper-warm); padding: 0.05rem 0.35rem; border-radius: 4px; font-size: 0.92em; }
  .section-ink code { background: rgba(250, 247, 242, 0.1); color: var(--paper); }
  .instr-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 0.85rem;
  }
  .instr-card {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    background: var(--surface-card);
    border: 1px solid var(--hairline);
    border-radius: var(--radius);
    padding: 1.05rem 1.2rem 1.1rem;
  }
  .instr-name {
    font-family: var(--font-display);
    font-size: 1.3rem;
    line-height: 1.05;
    color: var(--brand-teal-dark);
    font-variation-settings: 'opsz' 60, 'SOFT' 30;
  }
  .instr-use {
    font-size: 0.88rem;
    color: var(--stone-700);
    margin-top: 0.15rem;
  }
  .instr-full {
    font-size: 0.78rem;
    color: var(--stone-500);
    margin-top: 0.4rem;
    line-height: 1.4;
  }

  .pipeline {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 0;
    border-top: 1px solid rgba(250, 247, 242, 0.08);
    border-bottom: 1px solid rgba(250, 247, 242, 0.08);
  }
  .pipeline li {
    padding: 1.5rem 1.25rem;
    border-right: 1px solid rgba(250, 247, 242, 0.08);
  }
  .pipeline li:last-child { border-right: 0; }
  .pipeline .step {
    display: inline-block;
    font-family: var(--font-display);
    font-size: 1.6rem;
    color: var(--brand-teal-soft);
    margin-bottom: 0.5rem;
  }
  .pipeline h4 { color: var(--paper); font-size: 1rem; font-family: var(--font-sans); font-weight: 600; margin-bottom: 0.4rem; }
  .pipeline p { color: rgba(250, 247, 242, 0.6); font-size: 0.88rem; line-height: 1.55; }

  @media (max-width: 1100px) { .pipeline { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 600px) { .pipeline { grid-template-columns: 1fr; } .pipeline li { border-right: 0; border-bottom: 1px solid rgba(250, 247, 242, 0.08); } }

  .card h4 { font-family: var(--font-sans); font-size: 1.05rem; font-weight: 600; margin-bottom: 0.5rem; }
  .card p { color: var(--stone-700); font-size: 0.95rem; line-height: 1.6; }
</style>
