---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import DemoForm from '../components/DemoForm.astro';
---
<BaseLayout
  title="Request access"
  description="Praxnote is in early access. Tell us about your practice and we'll book a 30-minute walk-through on your actual workflow — notes, supervision, billing, or all three."
>
  <PageHeader
    eyebrow="Request access"
    title="Bring Praxnote into your <em>real</em> practice."
    lede="Praxnote is in early access. The fastest way to know whether it fits is to spend thirty minutes seeing it on the work you actually do — drafting a recent note, clearing a supervision queue, sending an invoice, walking through a right-to-be-forgotten request."
  />

  <section class="demo-grid-section">
    <div class="container">
      <div class="demo-grid">
        <div class="demo-form-side">
          <h2>Tell us about your practice.</h2>
          <p class="lede">
            We reply within one business day with two or three times that might work. No
            marketing list, no follow-up sequence — just the conversation.
          </p>
          <div class="form-wrap">
            <DemoForm />
          </div>
        </div>
        <aside class="demo-side">
          <div class="card-warm">
            <h3>What we'll walk through</h3>
            <ul class="checks">
              <li>Drafting a session note from a brief summary or a recording</li>
              <li>Editing a treatment plan in your preferred format (PBT, CBT, DBT, standard, plain narrative)</li>
              <li>Working through the supervision screen — approving, sending back, setting aside for discussion</li>
              <li>Sending an invoice and setting a client up on autopay</li>
              <li>Walking through a right-to-be-forgotten request from start to finish</li>
              <li>Opening one of the AI templates, changing a piece of it, and seeing the next draft reflect the change</li>
            </ul>
          </div>

          <div class="card">
            <h3>Who you'll meet</h3>
            <p class="muted">
              Someone from the Praxnote team — usually the founder for solo and small group
              practices, or a clinically-trained colleague for larger ones. No sales scripts,
              no gatekeeping.
            </p>
          </div>

          <div class="card">
            <h3>Already a Praxnote practice?</h3>
            <p class="muted">
              Email <a href="mailto:support@praxnote.com">support@praxnote.com</a> and we'll
              route you to the right person.
            </p>
          </div>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .demo-grid-section { padding-top: 0; }
  .demo-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: clamp(2rem, 4vw, 3.5rem);
    align-items: start;
  }
  .demo-form-side .lede { margin: 0.85rem 0 2rem; }
  .form-wrap {
    background: var(--surface-card);
    border: 1px solid var(--hairline);
    border-radius: var(--radius-lg);
    padding: clamp(1.5rem, 2.5vw, 2.25rem);
  }
  .demo-side {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    position: sticky;
    top: 100px;
  }
  .demo-side h3 { font-size: 1.1rem; margin-bottom: 0.85rem; }
  @media (max-width: 980px) {
    .demo-grid { grid-template-columns: 1fr; }
    .demo-side { position: static; }
  }
</style>
