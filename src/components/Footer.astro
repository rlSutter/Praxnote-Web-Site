---
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href="/" class="logo">prax<span>note</span></a>
        <p class="tagline">Notes in minutes. Nuance intact. Control yours.</p>
        <div class="brand-marks">
          <span class="badge badge-stone">HIPAA-aligned</span>
          <span class="badge badge-stone">GDPR-style erasure</span>
          <span class="badge badge-stone">BAA available</span>
        </div>
      </div>
      <div class="footer-col">
        <h4>Product</h4>
        <a href="/product">Platform overview</a>
        <a href="/features/supervision">Supervision queue</a>
        <a href="/features/ai-skills">AI skills</a>
        <a href="/features/session-notes">Session notes</a>
        <a href="/features/treatment-plans">Treatment plans</a>
        <a href="/features/assessments">Assessments</a>
        <a href="/features/client-portal">Client portal</a>
        <a href="/features/billing">Billing</a>
        <a href="/features/scheduling">Scheduling</a>
        <a href="/features/offline-vault">Offline vault</a>
        <a href="/deployment">Deployment (Cloud vs. Dedicated)</a>
      </div>
      <div class="footer-col">
        <h4>Solutions</h4>
        <a href="/solutions/solo-clinicians">Solo clinicians</a>
        <a href="/solutions/group-practices">Group practices</a>
        <a href="/solutions/supervisors">Supervisors</a>
        <a href="/solutions/practice-admins">Practice admins</a>
      </div>
      <div class="footer-col">
        <h4>Trust</h4>
        <a href="/security">Security overview</a>
        <a href="/security/compliance">HIPAA · GDPR</a>
        <a href="/security/baa">Request a BAA</a>
        <a href="/status">System status</a>
        <a href="/legal/privacy">Privacy policy</a>
        <a href="/legal/terms">Terms of service</a>
      </div>
      <div class="footer-col">
        <h4>Company</h4>
        <a href="/about">About</a>
        <a href="/services">Services</a>
        <a href="/pricing">Pricing</a>
        <a href="/roadmap">Roadmap</a>
        <a href="/changelog">Changelog</a>
        <a href="/resources">Resources</a>
        <a href="/resources/comparisons">Comparisons</a>
        <a href="/contact">Contact</a>
        <a href="/demo">Request access</a>
      </div>
    </div>

    <div class="footer-meta">
      <div>© {year} Praxnote. Built for behavioral health.</div>
      <div class="footer-fineprint">
        Praxnote is a clinical documentation and practice management platform. Not a covered entity. Not a clinician.
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--surface-ink);
    color: rgba(250, 247, 242, 0.7);
    padding: 4.5rem 0 2.5rem;
    margin-top: 0;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.5fr repeat(4, 1fr);
    gap: 2.5rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid rgba(250, 247, 242, 0.08);
  }

  .footer-brand .logo {
    font-family: var(--font-display);
    font-size: 1.6rem;
    color: var(--paper);
    text-decoration: none;
  }

  .footer-brand .logo span { color: var(--brand-teal-soft); font-style: italic; }

  .tagline {
    margin-top: 0.6rem;
    font-size: 0.95rem;
    color: rgba(250, 247, 242, 0.55);
    max-width: 280px;
    line-height: 1.55;
  }

  .brand-marks {
    margin-top: 1.25rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .brand-marks .badge {
    background: rgba(250, 247, 242, 0.06);
    border: 1px solid rgba(250, 247, 242, 0.12);
    color: rgba(250, 247, 242, 0.7);
    font-size: 0.72rem;
  }

  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .footer-col h4 {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--paper);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.35rem;
  }

  .footer-col a {
    color: rgba(250, 247, 242, 0.6);
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 160ms ease;
  }

  .footer-col a:hover { color: var(--paper); }

  .footer-meta {
    padding-top: 2rem;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 2rem;
    font-size: 0.82rem;
    color: rgba(250, 247, 242, 0.5);
  }

  .footer-fineprint {
    max-width: 480px;
    text-align: right;
  }

  @media (max-width: 980px) {
    .footer-grid { grid-template-columns: repeat(2, 1fr); }
    .footer-brand { grid-column: 1 / -1; }
  }

  @media (max-width: 600px) {
    .footer-grid { grid-template-columns: 1fr; gap: 2rem; }
    .footer-meta { flex-direction: column; gap: 0.75rem; }
    .footer-fineprint { text-align: left; }
  }
</style>
