---
interface Props {
  eyebrow?: string;
  heading?: string;
  body?: string;
  primaryHref?: string;
  primaryLabel?: string;
  secondaryHref?: string;
  secondaryLabel?: string;
  variant?: 'ink' | 'paper';
}

const {
  eyebrow = 'See it in your workflow',
  heading = 'Bring Praxnote into your next session.',
  body = 'A 30-minute walkthrough on your real workflow, documentation, supervision, billing, or all three. We tailor the demo to the role you actually do.',
  primaryHref = '/demo',
  primaryLabel = 'Book a demo',
  secondaryHref = '/security',
  secondaryLabel = 'Read the security overview',
  variant = 'ink',
} = Astro.props;
---
<section class={variant === 'ink' ? 'cta section-ink' : 'cta cta-paper'}>
  <div class="container cta-inner">
    <p class="eyebrow">{eyebrow}</p>
    <h2>{heading}</h2>
    <p class="lede">{body}</p>
    <div class="cta-actions">
      <a href={primaryHref} class="btn btn-primary btn-lg">{primaryLabel}</a>
      <a href={secondaryHref} class="btn-secondary-link">{secondaryLabel} →</a>
    </div>
  </div>
</section>

<style>
  .cta { padding: clamp(4rem, 7vw, 6.5rem) 0; text-align: left; }

  .cta-inner { max-width: 780px; }

  .cta-paper {
    background: var(--paper-warm);
    border-top: 1px solid var(--hairline);
  }

  .cta h2 { margin: 0.4rem 0 1rem; }

  .cta-actions {
    margin-top: 2rem;
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
    align-items: center;
  }

  .btn-lg { padding: 1rem 1.9rem; font-size: 1rem; }

  .btn-secondary-link {
    color: var(--brand-teal-soft);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
  }

  .cta-paper .btn-secondary-link { color: var(--brand-teal-dark); }

  .btn-secondary-link:hover { text-decoration: underline; }
</style>
